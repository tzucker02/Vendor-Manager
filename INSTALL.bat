@echo offsetlocal enabledelayedexpansionecho ========================================echo   Vendor Manager - Windows Setupecho ========================================echo.REM Parse argumentsset SKIP_SYSTEM=falseset RUN_APP=false:loopif "%~1"=="" goto endloopif /i "%~1"=="--skip-system" set SKIP_SYSTEM=trueif /i "%~1"=="--run-app" set RUN_APP=trueshiftgoto loop:endloopecho [1/4] Checking for Python...python --version >nul 2>&1if %ERRORLEVEL% NEQ 0 (    echo   ERROR: Python not found. Please install Python 3.9+ from https://www.python.org/downloads/    echo   IMPORTANT: Check 'Add Python to PATH' during installation.    pause    exit /b 1)for /f "tokens=*" %%i in ('python --version') do set PYTHON_VERSION=%%iecho   Found: !PYTHON_VERSION!echo.echo [2/4] Checking for Tesseract OCR...where tesseract >nul 2>&1if %ERRORLEVEL% NEQ 0 (    if "!SKIP_SYSTEM!"=="true" (        echo   [WARN] Skipping Tesseract installation by request.        echo   OCR feature will not work without Tesseract.    ) else (        echo   WARNING: Tesseract not found in PATH.        echo   Tesseract is REQUIRED for the OCR scanning feature.        echo.        set /p INSTALL_CHOICE="Do you want to open the Tesseract download page? (Y/N): "        if /i "!INSTALL_CHOICE!"=="Y" (            start https://github.com/UB-Mannheim/tesseract/wiki            echo.            echo   INSTRUCTIONS:            echo   1. Download the latest installer (e.g., tesseract-ocr-w64-setup-5.x.x.exe).            echo   2. Run the installer.            echo   3. IMPORTANT: During installation, CHECK the box to 'Add Tesseract to PATH'.            echo   4. Restart this script after installation.            pause            exit /b 1        ) else (            echo   Aborting. Tesseract is required for OCR.            pause            exit /b 1        )    )) else (    for /f "tokens=*" %%i in ('tesseract --version') do set TESS_VERSION=%%i    echo   Found: !TESS_VERSION!)echo.echo [3/4] Creating virtual environment...if exist .venv (    echo   Removing existing .venv...    rmdir /s /q .venv)python -m venv .venvecho   Virtual environment created.echo.echo [4/4] Installing Python dependencies...call .venv\Scripts\python.exe -m pip install --upgrade pipcall .venv\Scripts\python.exe -m pip install -r requirements.txtecho   Dependencies installed successfully!echo.echo ========================================echo   Setup Complete!echo ========================================echo.echo To activate the environment and run the app:echo   .venv\Scripts\activate.batecho   python vendor_manager.pyecho.echo Or run directly:echo   .venv\Scripts\python.exe vendor_manager.pyecho.if "!RUN_APP!"=="true" (    echo Launching Vendor Manager...    .venv\Scripts\python.exe vendor_manager.py)pause